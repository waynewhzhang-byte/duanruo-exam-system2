<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Exclude generated code -->
    <Match>
        <Source name="~.*[\\/]target[\\/]generated-sources[\\/].*"/>
    </Match>
    
    <!-- Exclude MapStruct generated classes -->
    <Match>
        <Class name="~.*Impl"/>
    </Match>
    <Match>
        <Class name="~.*MapperImpl"/>
    </Match>
    
    <!-- Exclude test classes from certain checks -->
    <Match>
        <Class name="~.*Test"/>
        <Bug pattern="DM_EXIT"/>
    </Match>
    <Match>
        <Class name="~.*Tests"/>
        <Bug pattern="DM_EXIT"/>
    </Match>
    
    <!-- Exclude JPA entities from serialization warnings -->
    <Match>
        <Package name="~.*\.infrastructure\..*"/>
        <Bug pattern="SE_BAD_FIELD"/>
    </Match>
    <Match>
        <Package name="~.*\.infrastructure\..*"/>
        <Bug pattern="SE_NO_SERIALVERSIONID"/>
    </Match>
    
    <!-- Exclude Spring Boot configuration classes -->
    <Match>
        <Class name="~.*Config"/>
        <Bug pattern="UWF_UNWRITTEN_FIELD"/>
    </Match>
    <Match>
        <Class name="~.*Configuration"/>
        <Bug pattern="UWF_UNWRITTEN_FIELD"/>
    </Match>
    
    <!-- Exclude Spring Boot main application class -->
    <Match>
        <Class name="~.*Application"/>
        <Bug pattern="DM_EXIT"/>
    </Match>
    
    <!-- Exclude certain patterns for domain objects -->
    <Match>
        <Package name="~.*\.domain\..*"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Package name="~.*\.domain\..*"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    
    <!-- Exclude null pointer warnings for validation annotations -->
    <Match>
        <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
        <Method name="~.*validate.*"/>
    </Match>
    
    <!-- Exclude unused field warnings for injected fields -->
    <Match>
        <Bug pattern="UWF_UNWRITTEN_FIELD"/>
        <Field name="~.*"/>
        <Class name="~.*Controller"/>
    </Match>
    <Match>
        <Bug pattern="UWF_UNWRITTEN_FIELD"/>
        <Field name="~.*"/>
        <Class name="~.*Service"/>
    </Match>
    <Match>
        <Bug pattern="UWF_UNWRITTEN_FIELD"/>
        <Field name="~.*"/>
        <Class name="~.*Repository"/>
    </Match>
</FindBugsFilter>
