<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>
    <!-- Suppress checks for generated code -->
    <suppress checks=".*" files=".*[\\/]target[\\/]generated-sources[\\/].*"/>
    <suppress checks=".*" files=".*[\\/]target[\\/]generated-test-sources[\\/].*"/>
    
    <!-- Suppress checks for MapStruct generated classes -->
    <suppress checks=".*" files=".*Impl\.java"/>
    <suppress checks=".*" files=".*MapperImpl\.java"/>
    
    <!-- Suppress utility class constructor check for Spring Boot main class -->
    <suppress checks="HideUtilityClassConstructor" files=".*Application\.java"/>
    
    <!-- Suppress design for extension for JPA entities -->
    <suppress checks="DesignForExtension" files=".*[\\/]infrastructure[\\/].*Entity\.java"/>
    
    <!-- Suppress magic number check for test classes -->
    <suppress checks="MagicNumber" files=".*Test\.java"/>
    <suppress checks="MagicNumber" files=".*Tests\.java"/>
    
    <!-- Suppress JavaDoc checks for test classes -->
    <suppress checks="JavadocType" files=".*Test\.java"/>
    <suppress checks="JavadocType" files=".*Tests\.java"/>
    <suppress checks="JavadocMethod" files=".*Test\.java"/>
    <suppress checks="JavadocMethod" files=".*Tests\.java"/>
    <suppress checks="JavadocVariable" files=".*Test\.java"/>
    <suppress checks="JavadocVariable" files=".*Tests\.java"/>
    
    <!-- Suppress final parameters for Spring configuration classes -->
    <suppress checks="FinalParameters" files=".*Config\.java"/>
    <suppress checks="FinalParameters" files=".*Configuration\.java"/>
    
    <!-- Suppress visibility modifier for JPA entities -->
    <suppress checks="VisibilityModifier" files=".*[\\/]infrastructure[\\/].*Entity\.java"/>
    
    <!-- Suppress line length for long URLs or SQL queries -->
    <suppress checks="LineLength" files=".*\.sql"/>
</suppressions>
