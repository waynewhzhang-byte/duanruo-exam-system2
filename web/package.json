{
  "name": "web",
  "version": "1.0.0",
  "description": "端若数智考盟前端应用",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:ui-bdd": "playwright test tests/e2e/ui-bdd/ --headed",
    "test:ui-bdd:all": "playwright test tests/e2e/ui-bdd/",
    "test:ui-bdd:super-admin": "playwright test tests/e2e/ui-bdd/01-super-admin.spec.ts --headed",
    "test:ui-bdd:tenant-admin": "playwright test tests/e2e/ui-bdd/02-tenant-admin.spec.ts --headed",
    "test:ui-bdd:candidate": "playwright test tests/e2e/ui-bdd/03-candidate.spec.ts --headed",
    "test:ui-bdd:reviewer": "playwright test tests/e2e/ui-bdd/04-reviewer.spec.ts --headed",
    "test:ui-bdd:debug": "playwright test tests/e2e/ui-bdd/ --debug",
    "test:setup": "playwright install",
    "test:bdd": "cucumber-js",
    "test:bdd:smoke": "cucumber-js --profile smoke",
    "test:bdd:p0": "cucumber-js --profile p0",
    "test:bdd:p1": "cucumber-js --profile p1",
    "test:bdd:report": "cucumber-js --format html:test-results/bdd/cucumber-report.html",
    "test:bdd:layered": "cucumber-js --config cucumber-layered.js",
    "test:bdd:layer-0": "cucumber-js --config cucumber-layered.js --profile layer-0",
    "test:bdd:layer-1": "cucumber-js --config cucumber-layered.js --profile layer-1",
    "test:bdd:layer-2": "cucumber-js --config cucumber-layered.js --profile layer-2",
    "test:bdd:layer-3": "cucumber-js --config cucumber-layered.js --profile layer-3",
    "test:bdd:layer-4": "cucumber-js --config cucumber-layered.js --profile layer-4",
    "test:bdd:layer-5": "cucumber-js --config cucumber-layered.js --profile layer-5",
    "test:bdd:layer-6": "cucumber-js --config cucumber-layered.js --profile layer-6",
    "test:bdd:layer-7": "cucumber-js --config cucumber-layered.js --profile layer-7",
    "test:bdd:all-layers": "npm run test:bdd:layer-0 && npm run test:bdd:layer-1 && npm run test:bdd:layer-2 && npm run test:bdd:layer-3 && npm run test:bdd:layer-4 && npm run test:bdd:layer-5 && npm run test:bdd:layer-6 && npm run test:bdd:layer-7",
    "test:bdd:ready": "cucumber-js --config cucumber-layered.js --tags \"not @wip\"",
    "test:bdd:layer-0:ready": "cucumber-js --config cucumber-layered.js --profile layer-0 --tags \"not @wip\"",
    "test:bdd:layer-1:ready": "cucumber-js --config cucumber-layered.js --profile layer-1 --tags \"not @wip\"",
    "test:bdd:wip": "cucumber-js --config cucumber-layered.js --tags @wip",
    "test:bdd:tenant-schema": "node --env-file=../server/.env ./node_modules/.bin/cucumber-js --config cucumber-tenant-schema.js",
    "test:bdd:tenant-admin-exam": "node --env-file=../server/.env ./node_modules/.bin/cucumber-js --config cucumber-tenant-admin-exam.js",
    "test:bdd:critical": "cucumber-js --config cucumber-layered.js --profile critical",
    "test:bdd:security": "cucumber-js --config cucumber-layered.js --profile security",
    "openapi:generate": "node scripts/generate-api-client.js",
    "openapi:validate": "node openapi/validate-spec.js",
    "openapi:export": "curl -s http://localhost:8081/api/v1/v3/api-docs -o openapi/exam-system-api.json",
    "openapi:refresh": "npm run openapi:export && npm run openapi:generate",
    "test:contract": "dredd",
    "test:contract:dry": "dredd --dry-run",
    "test:contract:init": "dredd init",
    "test:contract:report": "start test-results/contract/dredd-report.html"
  },
  "keywords": [
    "exam",
    "recruitment",
    "nextjs",
    "react"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-aspect-ratio": "^1.0.3",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-hover-card": "^1.0.7",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-menubar": "^1.0.4",
    "@radix-ui/react-navigation-menu": "^1.1.4",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-toggle": "^1.0.3",
    "@radix-ui/react-toggle-group": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tanstack/react-query": "^5.87.4",
    "@tanstack/react-table": "^8.21.3",
    "@types/node": "24.1.0",
    "@types/react": "19.1.8",
    "@types/react-dom": "18.2.18",
    "axios": "^1.12.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^0.2.0",
    "date-fns": "^2.30.0",
    "eslint": "8.56.0",
    "eslint-config-next": "14.2.5",
    "lucide-react": "^0.525.0",
    "next": "14.2.5",
    "papaparse": "^5.5.3",
    "react": "18.3.1",
    "react-day-picker": "^8.10.0",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.48.2",
    "react-pdf": "^10.2.0",
    "react-quill": "^2.0.0",
    "recharts": "^2.15.4",
    "sonner": "^1.3.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "5.8.3",
    "vaul": "^0.7.9",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.1.0",
    "@jest/globals": "^30.2.0",
    "@playwright/test": "^1.56.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.1",
    "@types/jest": "^30.0.0",
    "@types/papaparse": "^5.3.16",
    "@types/pg": "^8.15.5",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "10.4.16",
    "dredd": "^14.1.0",
    "jsdom": "^26.1.0",
    "openapi-fetch": "^0.13.8",
    "openapi-typescript": "^7.10.1",
    "pg": "^8.16.3",
    "postcss": "8.4.32",
    "tailwindcss": "3.4.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "vitest": "^4.0.16"
  }
}
