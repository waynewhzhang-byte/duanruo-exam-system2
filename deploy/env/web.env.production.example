# ==========================
# Web production env
# Path: web/.env.production
# ==========================

# For browser requests, keep relative path to use Next middleware proxy
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_API_BASE=/api/v1

# Optional: only needed by generated API client direct calls
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8081/api/v1

# Server-side proxy target in middleware.ts
BACKEND_PORT=8081
BACKEND_ORIGIN=http://127.0.0.1:8081
