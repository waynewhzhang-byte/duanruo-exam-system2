# ==========================
# Server production .env
# Path: server/.env
# ==========================

NODE_ENV=production
PORT=8081

# Database
DATABASE_URL=postgresql://postgres:CHANGE_ME@127.0.0.1:5432/duanruo_exam_system2

# JWT
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_WITH_32_PLUS_CHARS

# MinIO / Object Storage
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=exam-system
MINIO_PUBLIC_ENDPOINT=http://127.0.0.1:9000
MINIO_CORS_ORIGINS=*

# Optional
# REDIS_URL=redis://127.0.0.1:6379

# CORS allowed origins (comma-separated)
# CORS_ORIGINS=http://YOUR_PUBLIC_IP:3000,https://your-domain.com

# Swagger in production
SWAGGER_ENABLED=false
