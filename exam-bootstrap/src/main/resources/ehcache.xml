<?xml version="1.0" encoding="UTF-8"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.ehcache.org/v3"
        xsi:schemaLocation="http://www.ehcache.org/v3 http://www.ehcache.org/schema/ehcache-core-3.0.xsd">

    <!-- 默认缓存配置 -->
    <cache-template name="default">
        <expiry>
            <ttl unit="minutes">10</ttl>
        </expiry>
        <resources>
            <heap unit="entries">1000</heap>
            <offheap unit="MB">10</offheap>
        </resources>
    </cache-template>

    <!-- 实体缓存配置 -->
    
    <!-- 考试实体缓存 - 较长过期时间，因为考试信息不常变化 -->
    <cache alias="com.duanruo.exam.infrastructure.persistence.entity.ExamEntity" uses-template="default">
        <expiry>
            <ttl unit="minutes">30</ttl>
        </expiry>
        <resources>
            <heap unit="entries">500</heap>
            <offheap unit="MB">20</offheap>
        </resources>
    </cache>

    <!-- 岗位实体缓存 -->
    <cache alias="com.duanruo.exam.infrastructure.persistence.entity.PositionEntity" uses-template="default">
        <expiry>
            <ttl unit="minutes">30</ttl>
        </expiry>
        <resources>
            <heap unit="entries">1000</heap>
            <offheap unit="MB">10</offheap>
        </resources>
    </cache>

    <!-- 科目实体缓存 -->
    <cache alias="com.duanruo.exam.infrastructure.persistence.entity.SubjectEntity" uses-template="default">
        <expiry>
            <ttl unit="minutes">30</ttl>
        </expiry>
        <resources>
            <heap unit="entries">2000</heap>
            <offheap unit="MB">10</offheap>
        </resources>
    </cache>

    <!-- 用户实体缓存 - 较长过期时间 -->
    <cache alias="com.duanruo.exam.infrastructure.persistence.entity.UserEntity" uses-template="default">
        <expiry>
            <ttl unit="minutes">60</ttl>
        </expiry>
        <resources>
            <heap unit="entries">2000</heap>
            <offheap unit="MB">20</offheap>
        </resources>
    </cache>

    <!-- 租户实体缓存 - 很长过期时间，租户信息几乎不变 -->
    <cache alias="com.duanruo.exam.infrastructure.persistence.entity.TenantEntity" uses-template="default">
        <expiry>
            <ttl unit="hours">2</ttl>
        </expiry>
        <resources>
            <heap unit="entries">100</heap>
            <offheap unit="MB">5</offheap>
        </resources>
    </cache>

    <!-- 用户租户角色缓存 - 中等过期时间 -->
    <cache alias="com.duanruo.exam.infrastructure.persistence.entity.UserTenantRoleEntity" uses-template="default">
        <expiry>
            <ttl unit="minutes">30</ttl>
        </expiry>
        <resources>
            <heap unit="entries">5000</heap>
            <offheap unit="MB">20</offheap>
        </resources>
    </cache>

    <!-- 报名申请缓存 - 较短过期时间，因为状态经常变化 -->
    <cache alias="com.duanruo.exam.infrastructure.persistence.entity.ApplicationEntity" uses-template="default">
        <expiry>
            <ttl unit="minutes">5</ttl>
        </expiry>
        <resources>
            <heap unit="entries">5000</heap>
            <offheap unit="MB">50</offheap>
        </resources>
    </cache>

    <!-- 审核记录缓存 -->
    <cache alias="com.duanruo.exam.infrastructure.persistence.entity.ReviewEntity" uses-template="default">
        <expiry>
            <ttl unit="minutes">15</ttl>
        </expiry>
        <resources>
            <heap unit="entries">10000</heap>
            <offheap unit="MB">30</offheap>
        </resources>
    </cache>

    <!-- 准考证缓存 -->
    <cache alias="com.duanruo.exam.infrastructure.persistence.entity.TicketEntity" uses-template="default">
        <expiry>
            <ttl unit="minutes">30</ttl>
        </expiry>
        <resources>
            <heap unit="entries">5000</heap>
            <offheap unit="MB">20</offheap>
        </resources>
    </cache>

    <!-- 查询缓存 - 用于缓存查询结果 -->
    <cache alias="default-query-results-region" uses-template="default">
        <expiry>
            <ttl unit="minutes">5</ttl>
        </expiry>
        <resources>
            <heap unit="entries">5000</heap>
            <offheap unit="MB">50</offheap>
        </resources>
    </cache>

    <!-- 更新时间戳缓存 - 用于跟踪实体更新 -->
    <cache alias="default-update-timestamps-region">
        <expiry>
            <none/>
        </expiry>
        <resources>
            <heap unit="entries">10000</heap>
        </resources>
    </cache>

    <!-- 集合缓存 - 用于缓存实体的集合关系 -->
    <cache alias="com.duanruo.exam.infrastructure.persistence.entity.ExamEntity.positions" uses-template="default">
        <expiry>
            <ttl unit="minutes">30</ttl>
        </expiry>
        <resources>
            <heap unit="entries">500</heap>
            <offheap unit="MB">10</offheap>
        </resources>
    </cache>

    <cache alias="com.duanruo.exam.infrastructure.persistence.entity.PositionEntity.subjects" uses-template="default">
        <expiry>
            <ttl unit="minutes">30</ttl>
        </expiry>
        <resources>
            <heap unit="entries">1000</heap>
            <offheap unit="MB">10</offheap>
        </resources>
    </cache>

</config>

