// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "tenant"]
}

// --- Public Schema Tables ---

model User {
  id                String    @id @default(uuid()) @db.Uuid
  username          String    @unique @db.VarChar(50)
  email             String    @unique @db.VarChar(100)
  passwordHash      String    @map("password_hash") @db.VarChar(255)
  fullName          String    @map("full_name") @db.VarChar(100)
  phoneNumber       String?   @unique @map("phone_number") @db.VarChar(20)
  status            String    @default("ACTIVE") @db.VarChar(50)
  roles             String    @db.Text // JSON string: ["ADMIN", "CANDIDATE", etc.]
  lastLoginAt       DateTime? @map("last_login_at")
  passwordChangedAt DateTime? @map("password_changed_at")
  emailVerified     Boolean   @default(false) @map("email_verified")
  phoneVerified     Boolean   @default(false) @map("phone_verified")
  department        String?   @db.VarChar(100)
  jobTitle          String?   @map("job_title") @db.VarChar(100)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  version           BigInt    @default(0)

  tenantRoles       UserTenantRole[]
  profile           UserProfile?

  @@map("users")
  @@schema("public")
}

model UserProfile {
  id                  String              @id @default(uuid()) @db.Uuid
  userId              String              @unique @map("user_id") @db.Uuid
  gender              String?             @db.VarChar(10)
  birthDate           DateTime?           @map("birth_date")
  idNumber            String?             @map("id_number") @db.VarChar(50)
  idNumberEncrypted   Boolean             @default(false) @map("id_number_encrypted")
  politicalStatus     String?             @map("political_status") @db.VarChar(20)
  hukouLocation       String?             @map("hukou_location") @db.VarChar(200)
  workExperience      String?             @map("work_experience") @db.VarChar(100)
  photoId             String?             @map("photo_id") @db.Uuid
  education           String?             @db.VarChar(50)
  major               String?             @db.VarChar(100)
  graduateYear        Int?                @map("graduate_year")
  university          String?             @db.VarChar(200)
  currentCompany      String?             @map("current_company") @db.VarChar(200)
  currentPosition     String?             @map("current_position") @db.VarChar(100)
  emergencyContact    String?             @map("emergency_contact") @db.VarChar(100)
  emergencyPhone      String?             @map("emergency_phone") @db.VarChar(20)
  address             String?             @db.VarChar(300)
  customFields        Json?               @map("custom_fields")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
  @@schema("public")
}

model Tenant {
  id            String    @id @default(uuid()) @db.Uuid
  name          String    @db.VarChar(100)
  code          String    @unique @db.VarChar(50)
  schemaName    String    @unique @map("schema_name") @db.VarChar(63)
  status        String    @default("PENDING") @db.VarChar(20)
  contactEmail  String    @map("contact_email") @db.VarChar(100)
  contactPhone  String?   @map("contact_phone") @db.VarChar(20)
  description   String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  activatedAt   DateTime? @map("activated_at")
  deactivatedAt DateTime? @map("deactivated_at")

  userRoles     UserTenantRole[]

  @@map("tenants")
  @@schema("public")
}

model UserTenantRole {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  role      String    @db.VarChar(50)
  grantedAt DateTime  @default(now()) @map("granted_at")
  grantedBy String?   @map("granted_by") @db.Uuid
  revokedAt DateTime? @map("revoked_at")
  revokedBy String?   @map("revoked_by") @db.Uuid
  active    Boolean   @default(true)

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId, role])
  @@map("user_tenant_roles")
  @@schema("public")
}

model SecurityAuditLog {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String?   @map("user_id") @db.Uuid
  username        String?   @db.VarChar(100)
  action          String    @db.VarChar(100)
  resource        String?   @db.VarChar(100)
  resourceId      String?   @map("resource_id") @db.VarChar(100)
  details          Json?
  ipAddress       String?   @map("ip_address") @db.VarChar(45)
  userAgent       String?   @map("user_agent") @db.Text
  success         Boolean  @default(true)
  errorMessage     String?   @map("error_message") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([action])
  @@index([userId], map: "security_audit_logs_user_id_idx")
  @@index([createdAt], map: "security_audit_logs_created_at_idx")
  @@map("security_audit_logs")
  @@schema("public")
}

// --- Tenant Schema Tables ---
// These models use @@schema("tenant") to route to tenant schemas.
// Prisma generates fully-qualified SQL: "tenant"."exams" etc.
// At runtime, TenantPoolWrapper rewrites "tenant"."table" → "tenant_{code}"."table"
// while queries to "public"."users" etc. pass through unchanged.

model Exam {
  id                String    @id @default(uuid()) @db.Uuid
  code              String    @unique @db.VarChar(64)
  title             String    @db.VarChar(255)
  description       String?   @db.Text
  announcement      String?   @db.Text
  registrationStart DateTime? @map("registration_start")
  registrationEnd   DateTime? @map("registration_end")
  examStart         DateTime? @map("exam_start")
  examEnd           DateTime? @map("exam_end")
  feeRequired       Boolean   @default(false) @map("fee_required")
  feeAmount         Decimal?  @map("fee_amount") @db.Decimal(10, 2)
  ticketTemplate    String?   @map("ticket_template") @db.Text
  formTemplate      Json?     @map("form_template") @db.JsonB
  formTemplateId    String?   @map("form_template_id") @db.Uuid
  status            String    @default("DRAFT") @db.VarChar(50) // DRAFT, REGISTRATION_OPEN, OPEN, CLOSED, IN_PROGRESS, COMPLETED
  createdBy         String?   @map("created_by") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  positions         Position[]
  applications      Application[]

  @@map("exams")
  @@schema("tenant")
}

model Position {
  id           String    @id @default(uuid()) @db.Uuid
  examId       String    @map("exam_id") @db.Uuid
  code         String    @db.VarChar(64)
  title        String    @db.VarChar(255)
  description  String?   @db.Text
  requirements String?   @db.Text
  quota        Int?
  rulesConfig  Json?     @map("rules_config") @db.JsonB
  createdAt    DateTime  @default(now()) @map("created_at")

  exam         Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  subjects     Subject[]
  applications Application[]

  @@unique([examId, code])
  @@map("positions")
  @@schema("tenant")
}

model Subject {
  id              String    @id @default(uuid()) @db.Uuid
  positionId      String    @map("position_id") @db.Uuid
  name            String    @db.VarChar(255)
  durationMinutes Int       @map("duration")
  type            String    @db.VarChar(64) // WRITTEN, INTERVIEW, PRACTICAL
  maxScore        Decimal?  @map("max_score") @db.Decimal(5, 2)
  passingScore    Decimal?  @map("passing_score") @db.Decimal(5, 2)
  weight          Decimal   @default(1.0) @db.Decimal(3, 2)
  ordering        Int       @default(0)
  schedule        Json?     @db.JsonB
  createdAt       DateTime  @default(now()) @map("created_at")

  position        Position  @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@map("subjects")
  @@schema("tenant")
}

model Application {
  id                   String    @id @default(uuid()) @db.Uuid
  candidateId          String    @map("candidate_id") @db.Uuid
  examId               String    @map("exam_id") @db.Uuid
  positionId           String    @map("position_id") @db.Uuid
  formVersion          Int       @default(1) @map("form_version")
  payload              Json      @db.JsonB // JSON form data
  status               String    @default("DRAFT") @db.VarChar(50) 
  submittedAt          DateTime? @map("submitted_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  // 成绩相关字段
  totalWrittenScore   Decimal?  @map("total_written_score") @db.Decimal(6, 2)   // 笔试总分
  writtenPassScore    Decimal?  @map("written_pass_score") @db.Decimal(5, 2)     // 笔试合格线
  writtenPassStatus   String?   @map("written_pass_status")                     // PASS, FAIL, PENDING, EXEMPT
  interviewEligibility String?  @map("interview_eligibility")                   // ELIGIBLE, INELIGIBLE, PENDING, EXEMPT
  finalResult        String?   @map("final_result")                             // 待定, 进入面试, 面试通过, 面试未通过, 笔试未通过
  
  // 面试安排
  interviewTime       DateTime? @map("interview_time")
  interviewLocation   String?   @map("interview_location") @db.VarChar(255)
  interviewRoom       String?   @map("interview_room") @db.VarChar(100)

  exam                 Exam      @relation(fields: [examId], references: [id])
  position             Position  @relation(fields: [positionId], references: [id])
  attachments          FileRecord[]
  scores              ExamScore[]

  @@unique([examId, candidateId])
  @@map("applications")
  @@schema("tenant")
}

model ApplicationAuditLog {
  id            String    @id @default(uuid()) @db.Uuid
  applicationId String    @map("application_id") @db.Uuid
  fromStatus    String?   @map("from_status") @db.VarChar(50)
  toStatus      String    @map("to_status") @db.VarChar(50)
  actor         String?   @db.VarChar(100)
  reason        String?   @db.Text
  metadata      Json?     @db.JsonB
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("application_audit_logs")
  @@schema("tenant")
}

model ReviewTask {
  id              String    @id @default(uuid()) @db.Uuid
  applicationId   String    @map("application_id") @db.Uuid
  stage           String    @db.VarChar(32) // PRIMARY, SECONDARY
  status          String    @db.VarChar(32) // OPEN, ASSIGNED, COMPLETED, CANCELLED
  assignedTo      String?   @map("assigned_to") @db.Uuid
  lockedAt        DateTime? @map("locked_at")
  lastHeartbeatAt DateTime? @map("last_heartbeat_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([applicationId, stage])
  @@index([assignedTo, status])
  @@map("review_tasks")
  @@schema("tenant")
}

model Review {
  id            String    @id @default(uuid()) @db.Uuid
  applicationId String    @map("application_id") @db.Uuid
  stage         String    @db.VarChar(50) // PRIMARY, SECONDARY
  reviewerId    String    @map("reviewer_id") @db.Uuid
  decision      String?   @db.VarChar(50) // APPROVED, REJECTED, PENDING, RETURNED
  comment       String?   @db.Text
  reviewedAt    DateTime? @map("reviewed_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([applicationId])
  @@index([reviewerId])
  @@index([stage])
  @@index([decision])
  @@index([reviewedAt])
  @@map("reviews")
  @@schema("tenant")
}

model ExamReviewer {
  id         BigInt   @id @default(autoincrement())
  examId     String   @map("exam_id") @db.Uuid
  reviewerId String   @map("reviewer_id") @db.Uuid
  stage      String   @db.VarChar(32) // PRIMARY, SECONDARY
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([examId, reviewerId, stage])
  @@index([examId])
  @@index([reviewerId])
  @@map("exam_reviewers")
  @@schema("tenant")
}

model PaymentOrder {
  id            String    @id @default(uuid()) @db.Uuid
  applicationId String    @map("application_id") @db.Uuid
  outTradeNo    String    @unique @map("out_trade_no") @db.VarChar(64)
  amount        Decimal   @db.Decimal(10, 2)
  currency      String    @db.VarChar(10)
  channel       String    @db.VarChar(20) // ALIPAY, WECHAT, MOCK
  status        String    @db.VarChar(20) // PENDING, PROCESSING, SUCCESS, FAILED, CANCELLED
  transactionId String?   @map("transaction_id") @db.VarChar(128)
  paymentParams String?   @map("payment_params") @db.Text
  callbackData  String?   @map("callback_data") @db.Text
  failureReason String?   @map("failure_reason") @db.VarChar(500)
  paidAt        DateTime? @map("paid_at")
  expiredAt     DateTime? @map("expired_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([applicationId])
  @@index([transactionId])
  @@index([status])
  @@map("payment_orders")
  @@schema("tenant")
}

model Ticket {
  id              String    @id @default(uuid()) @db.Uuid
  applicationId   String    @map("application_id") @db.Uuid
  examId          String    @map("exam_id") @db.Uuid
  positionId      String    @map("position_id") @db.Uuid
  candidateId     String    @map("candidate_id") @db.Uuid
  ticketNo        String    @unique @map("ticket_no") @db.VarChar(100)
  ticketNumber    String    @map("ticket_number") @db.VarChar(100)
  status          String    @db.VarChar(20) // ACTIVE, CANCELLED, PRINTED
  candidateName   String?   @map("candidate_name") @db.VarChar(500)
  candidateIdNumber String? @map("candidate_id_number") @db.VarChar(500)
  candidatePhoto  String?   @map("candidate_photo") @db.VarChar(500)
  examTitle       String?   @map("exam_title") @db.VarChar(200)
  positionTitle   String?   @map("position_title") @db.VarChar(200)
  examStartTime   DateTime? @map("exam_start_time")
  examEndTime     DateTime? @map("exam_end_time")
  venueName       String?   @map("venue_name") @db.VarChar(200)
  roomNumber      String?   @map("room_number") @db.VarChar(50)
  seatNumber      String?   @map("seat_number") @db.VarChar(50)
  qrCode          String?   @map("qr_code") @db.Text
  barcode         String?   @map("barcode") @db.VarChar(100)
  issuedAt        DateTime  @map("issued_at")
  printedAt       DateTime? @map("printed_at")
  verifiedAt      DateTime? @map("verified_at")
  cancelledAt     DateTime? @map("cancelled_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("tickets")
  @@schema("tenant")
}

model SeatAssignment {
  id            String   @id @default(uuid()) @db.Uuid
  examId        String   @map("exam_id") @db.Uuid
  positionId    String   @map("position_id") @db.Uuid
  applicationId String   @unique @map("application_id") @db.Uuid
  venueId       String   @map("venue_id") @db.Uuid
  roomId        String?  @map("room_id") @db.Uuid
  seatNo        Int      @map("seat_no")
  seatLabel     String?  @map("seat_label") @db.VarChar(100)
  batchId       String?  @map("batch_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([examId])
  @@index([batchId])
  @@map("seat_assignments")
  @@schema("tenant")
}

model TicketNumberRule {
  examId              String   @id @map("exam_id") @db.Uuid
  customPrefix        String?  @map("custom_prefix") @db.VarChar(50)
  includeExamCode     Boolean  @map("include_exam_code")
  includeExamName     Boolean  @map("include_exam_name")
  includePositionCode Boolean  @map("include_position_code")
  includePositionName Boolean  @map("include_position_name")
  dateFormat          String   @map("date_format") @db.VarChar(20)
  sequenceLength      Int      @map("sequence_length")
  sequenceStart       Int      @map("sequence_start")
  dailyReset          Boolean  @map("daily_reset")
  checksumType        String   @map("checksum_type") @db.VarChar(20)
  separator           String   @map("separator") @db.VarChar(10)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("ticket_number_rules")
  @@schema("tenant")
}

model TicketSequence {
  examId       String   @map("exam_id") @db.Uuid
  scope        String   @db.VarChar(16) // GLOBAL or DAILY
  counterDate  DateTime @map("counter_date") @db.Date
  currentValue BigInt   @map("current_value")

  @@id([examId, scope, counterDate])
  @@map("ticket_sequences")
  @@schema("tenant")
}

model Venue {
  id          String   @id @default(uuid()) @db.Uuid
  examId      String   @map("exam_id") @db.Uuid
  name        String   @db.VarChar(255)
  capacity    Int
  seatMapJson Json?    @map("seat_map_json")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  rooms       Room[]

  @@index([examId])
  @@map("venues")
  @@schema("tenant")
}

model Room {
  id          String   @id @default(uuid()) @db.Uuid
  venueId     String   @map("venue_id") @db.Uuid
  name        String   @db.VarChar(255)
  code        String   @db.VarChar(64)
  capacity    Int
  floor       Int?
  description String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  venue       Venue    @relation(fields: [venueId], references: [id])

  @@index([venueId])
  @@map("rooms")
  @@schema("tenant")
}

model AllocationBatch {
  id              String   @id @default(uuid()) @db.Uuid
  examId          String   @map("exam_id") @db.Uuid
  strategy        String?  @db.Text
  totalCandidates Int      @map("total_candidates")
  totalAssigned   Int      @map("total_assigned")
  totalVenues     Int      @map("total_venues")
  createdAt       DateTime @default(now()) @map("created_at")
  createdBy       String?  @map("created_by")

  @@index([examId])
  @@map("allocation_batches")
  @@schema("tenant")
}

model FileRecord {
  id              String   @id @default(uuid()) @db.Uuid
  originalName    String   @map("original_name") @db.VarChar(255)
  storedName      String   @unique @map("stored_name") @db.VarChar(255)
  objectKey       String   @unique @map("object_key") @db.VarChar(255)
  contentType     String?  @map("content_type") @db.VarChar(100)
  fileSize        BigInt?  @map("file_size")
  fieldKey        String?  @map("field_key") @db.VarChar(100)
  applicationId   String?  @map("application_id") @db.Uuid
  application     Application? @relation(fields: [applicationId], references: [id])
  uploadedBy      String   @map("uploaded_by") @db.Uuid
  status          String   @default("UPLOADING") @db.VarChar(50) // UPLOADING, UPLOADED, AVAILABLE, DELETED, EXPIRED, QUARANTINED
  virusScanStatus String   @default("PENDING") @map("virus_scan_status") @db.VarChar(50) // PENDING, SCANNING, CLEAN, INFECTED, FAILED, SKIPPED
  virusScanResult String?  @map("virus_scan_result") @db.Text
  accessCount     Int      @default(0) @map("access_count")
  lastAccessedAt  DateTime? @map("last_accessed_at")
  expiresAt       DateTime? @map("expires_at")
  metadata        Json?    @db.JsonB
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("files")
  @@schema("tenant")
}

// ===== 成绩模型 =====
model ExamScore {
  id                String    @id @default(uuid()) @db.Uuid
  applicationId     String    @map("application_id") @db.Uuid
  subjectId         String    @map("subject_id") @db.Uuid
  candidateId       String    @map("candidate_id") @db.Uuid
  examId           String    @map("exam_id") @db.Uuid
  positionId        String    @map("position_id") @db.Uuid
  
  // 分数
  score             Decimal?  @map("score") @db.Decimal(5, 2)
  isAbsent          Boolean   @default(false) @map("is_absent")
  remarks           String?   @map("remarks") @db.Text
  
  // 面试资格判定
  interviewEligibility String?  @map("interview_eligibility")  // PASSED, FAILED, PENDING, EXEMPT
  interviewScore       Decimal?  @map("interview_score") @db.Decimal(5, 2)
  finalResult         String?   @map("final_result")  // 待定, 进入面试, 面试通过, 面试未通过
  
  // 元数据
  recordedBy        String?   @map("recorded_by") @db.Uuid
  recordedAt        DateTime  @default(now()) @map("recorded_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  
  application       Application @relation(fields: [applicationId], references: [id])
  
  @@unique([applicationId, subjectId])
  @@index([examId])
  @@index([candidateId])
  @@index([interviewEligibility])
  @@map("exam_scores")
  @@schema("tenant")
}

// ===== 通知记录模型 =====
model Notification {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  tenantId      String?   @map("tenant_id") @db.Uuid
  
  // 通知内容
  type          String    @map("type") @db.VarChar(50)  // SCORE_PUBLISHED, INTERVIEW_ELIGIBILITY, INTERVIEW_RESULT, TICKET_GENERATED 等
  title         String    @map("title") @db.VarChar(255)
  content       String    @map("content") @db.Text
  channel       String    @map("channel") @db.VarChar(20)  // EMAIL, SMS, SYSTEM
  
  // 发送状态
  status        String    @map("status") @default("PENDING") @db.VarChar(20)  // PENDING, SENT, FAILED
  sentAt        DateTime? @map("sent_at")
  readAt        DateTime? @map("read_at")
  
  // 关联
  relatedId     String?   @map("related_id") @db.Uuid
  relatedType   String?   @map("related_type")
  
  createdAt     DateTime  @default(now()) @map("created_at")
  
  @@index([userId, status])
  @@index([createdAt])
  @@map("notifications")
  @@schema("public")
}
