# Database
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/Duanruo-exam-system2"

# JWT
# Use a high-entropy secret with at least 32 characters.
JWT_SECRET="replace-with-a-random-secret-of-at-least-32-characters"

# Redis (optional, for caching)
# REDIS_URL="redis://localhost:6379"

# MinIO (Object Storage)
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="exam-system"
# Public endpoint for presigned URLs
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
# Allowed CORS origins for browser direct uploads (comma-separated)
MINIO_CORS_ORIGINS=*

# Application
NODE_ENV="development"
PORT=8081

# CORS (comma-separated origins, leave empty for production same-origin)
# CORS_ORIGINS="http://localhost:3000"

# Tenant schema auto-sync on startup (set to "false" to disable)
# TENANT_SCHEMA_AUTO_SYNC="true"